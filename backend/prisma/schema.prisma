generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PROCTOR_ADMIN
  PLATFORM_ADMIN
}

enum SessionStatus {
  PENDING
  PROCTOR_SETUP
  ACTIVE
  COMPLETED
  TERMINATED
  EXPIRED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          Role           @default(STUDENT)
  mfaSecret     String?
  verifiedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  streaks       Streak[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Session {
  id             String        @id @default(uuid())
  userId         String
  topicIds       String[]
  difficulty     String
  status         SessionStatus @default(PENDING)
  score          Int           @default(0)
  violationCount Int           @default(0)
  startedAt      DateTime?
  endsAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("sessions")
}

model Problem {
  id            String       @id @default(uuid())
  topic         String
  difficulty    String
  title         String
  description   String
  examples      Json
  constraints   Json
  isAiGenerated Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  submissions   Submission[]

  @@map("problems")
}

model Submission {
  id         String   @id @default(uuid())
  sessionId  String
  problemId  String
  language   String
  code       String
  verdict    String
  runtimeMs  Int?
  memoryKb   Int?
  submittedAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

// violation_events is a hypertable in TimescaleDB.
// Prisma doesn't natively manage hypertables, so we create the table here
// and will run a manual SQL migration to convert it to a hypertable.
model ViolationEvent {
  id        String   @id @default(uuid())
  sessionId String
  type      String
  severity  String
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([sessionId, timestamp(sort: Desc)])
  @@map("violation_events")
}

model Streak {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime @db.Date
  problemsSolved Int      @default(0)
  sessionCount   Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("streaks")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdIp  String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
